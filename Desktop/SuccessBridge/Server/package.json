{
  "name": "learning-platform-server",
  "version": "1.0.0",
  "description": "Scalable Learning Platform Backend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "node -e \"require('fs').rmSync('dist', {recursive: true, force: true})\"",
    "build": "npx tsc",
    "start": "node dist/index.js",
    "postbuild": "echo 'Build completed successfully'",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "seed:freshman": "tsx src/scripts/seedFreshmanResources.ts",
    "create:test-admin": "tsx src/scripts/createTestAdmin.ts",
    "seed:pending-admins": "tsx src/scripts/seedPendingAdmins.ts",
    "migrate:email-verification": "tsx src/scripts/migrateEmailVerification.ts",
    "migrate:pending-users": "tsx src/scripts/ensurePendingUsersTable.ts",
    "cleanup:pending-users": "tsx src/scripts/cleanupExpiredPendingUsers.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/s3-request-presigner": "^3.1033.0",
    "@google/generative-ai": "^0.24.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.4",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.11.0",
    "redis": "^4.6.0",
    "sequelize": "^6.35.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^5.3.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/helmet": "^0.0.48",
    "@types/multer-s3": "^3.0.3",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "tsx": "^4.7.0"
  }
}
