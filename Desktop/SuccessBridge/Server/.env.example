# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (Supabase Recommended)
# -----------------------------------------------------------------------------
# For production, use the Transaction or Session pooler URL from Supabase dashboard
DATABASE_URL=postgresql://postgres.[PROJ_ID]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require

# Individual components (Optional if DATABASE_URL is provided)
DB_HOST=aws-0-[REGION].pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.[PROJ_ID]
DB_PASSWORD=your-database-password

# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------
# Generate a random 32+ character string for production
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# SERVER & CORS
# -----------------------------------------------------------------------------
PORT=10000
NODE_ENV=production
# The public URL of your backend (e.g., https://api.successbridge.com)
BACKEND_URL=https://your-api-name.onrender.com
# The public URL of your frontend (e.g., https://successbridge.pages.dev)
FRONTEND_URL=https://your-frontend.pages.dev

# -----------------------------------------------------------------------------
# OAUTH CONFIGURATION (Google)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# STORAGE CONFIGURATION (Backblaze B2 or Supabase)
# -----------------------------------------------------------------------------
# Backblaze B2
B2_KEY_ID=your-key-id
B2_APPLICATION_KEY=your-application-key
B2_BUCKET_NAME=successbridge-resources
B2_BUCKET_ID=your-bucket-id
B2_ENDPOINT=s3.us-west-004.backblazeb2.com
B2_REGION=us-west-004

# Supabase Storage
SUPABASE_URL=https://[PROJ_ID].supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
FROM_EMAIL=noreply@successbridge.com
FROM_NAME="SuccessBridge"

# -----------------------------------------------------------------------------
# FILE UPLOAD SETTINGS
# -----------------------------------------------------------------------------
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads

# -----------------------------------------------------------------------------
# GEMINI AI CONFIGURATION
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your-google-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash