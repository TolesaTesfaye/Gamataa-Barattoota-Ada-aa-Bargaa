/**
 * EXAMPLE: How to add payment protection to Psychology subject
 * 
 * This file shows how to wrap existing Psychology content with payment protection.
 * Copy this pattern to any subject that requires payment.
 */

import React from 'react'
import { SubjectAccessGuard } from '@components/payment/SubjectAccessGuard'
import { SubjectChapterRenderer } from '@dashboards/student/components/SubjectChapterRenderer'
import { psychologyConfig } from './psychologyConfig'
import { psychologyContent } from './psychologyContent'

export const PsychologyPageWithPayment: React.FC = () => {
  // Get the subject ID from your subject registry or database
  // You'll need to fetch this from your subjects API or hardcode it
  const PSYCHOLOGY_SUBJECT_ID = 'your-psychology-subject-id-here'
  
  return (
    <SubjectAccessGuard
      subjectId={PSYCHOLOGY_SUBJECT_ID}
      subjectName="Psychology"
      educationLevel="university"
      grade="freshman"
      // Optional: List subjects that are free (don't require payment)
      freeSubjects={['English']} // English is free for freshman
    >
      {/* Your existing Psychology content goes here */}
      <SubjectChapterRenderer
        config={psychologyConfig}
        content={psychologyContent}
      />
    </SubjectAccessGuard>
  )
}

/**
 * INTEGRATION STEPS:
 * 
 * 1. Get Subject ID:
 *    - Query your subjects API to get the Psychology subject ID
 *    - Or create a subject registry that maps subject names to IDs
 * 
 * 2. Replace Original Component:
 *    - Find where PsychologyPage is used in your routes
 *    - Replace it with PsychologyPageWithPayment
 * 
 * 3. Configure Free Subjects:
 *    - Update the freeSubjects array with subjects that don't require payment
 *    - For example: ['English', 'Mathematics'] for freshman
 * 
 * 4. Test:
 *    - As a student, navigate to Psychology
 *    - You should see the payment prompt
 *    - Submit a payment request
 *    - As admin, approve the payment
 *    - As student, verify you can now access the content
 */

/**
 * ALTERNATIVE: Protect at Route Level
 * 
 * Instead of wrapping individual pages, you can protect at the route level:
 */

// In your routes file (e.g., App.tsx or routes.tsx):
/*
import { SubjectAccessGuard } from '@components/payment/SubjectAccessGuard'

<Route 
  path="/dashboard/learning/psychology" 
  element={
    <SubjectAccessGuard
      subjectId="psychology-id"
      subjectName="Psychology"
      educationLevel="university"
      grade="freshman"
      freeSubjects={['English']}
    >
      <PsychologyPage />
    </SubjectAccessGuard>
  } 
/>
*/

